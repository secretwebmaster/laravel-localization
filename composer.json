{
    "name": "secretwebmaster/laravel-localization",
    "description": "Easy localization for Laravel (forked for WNCMS fixes)",
    "keywords": [
        "localization",
        "laravel",
        "php",
        "wncms"
    ],
    "homepage": "https://github.com/secretwebmaster/laravel-localization",
    "license": "MIT",
    "authors": [
        {
            "name": "secretwebmaster",
            "email": "earnbyshare2016@gmail.com",
            "role": "Maintainer"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.5|^9.0|^10.0",
        "phpunit/phpunit": "^10.1|^11.0"
    },
    "conflict": {
        "mcamara/laravel-localization": "*"
    },
    "suggest": {
        "ext-intl": "*"
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "autoload": {
        "classmap": [],
        "psr-0": {
            "Mcamara\\LaravelLocalization": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mcamara\\LaravelLocalization\\Tests\\": "tests"
        }
    },
    "extra": {
        "laravel": {}
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
