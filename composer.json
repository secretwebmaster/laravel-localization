{
    "name": "secretwebmaster/laravel-localization",
    "description": "Easy localization for Laravel (forked for WNCMS fixes)",
    "keywords": [
        "localization",
        "laravel",
        "php",
        "wncms"
    ],
    "homepage": "https://github.com/secretwebmaster/laravel-localization",
    "license": "MIT",
    "authors": [
        {
            "name": "secretwebmaster",
            "email": "earnbyshare2016@gmail.com",
            "role": "Maintainer"
        }
    ],
    "require": {
        "php": "^8.4",
        "laravel/framework": "^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^11.0",
        "phpunit/phpunit": "^12.5"
    },
    "conflict": {
        "mcamara/laravel-localization": "*"
    },
    "suggest": {
        "ext-intl": "*"
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "autoload": {
        "classmap": [],
        "psr-0": {
            "Mcamara\\LaravelLocalization": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mcamara\\LaravelLocalization\\Tests\\": "tests"
        }
    },
    "extra": {
        "laravel": {},
        "branch-alias": {
            "dev-main": "2.4.x-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
