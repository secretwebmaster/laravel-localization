{
    "name": "secretwebmaster/laravel-localization",
    "description": "Fixed fork of mcamara/laravel-localization used by WNCMS",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^10.0|^11.0|^12.0"
    },
    "replace": {
        "mcamara/laravel-localization": "*"
    },
    "suggest": {
        "ext-intl": "*"
    },
    "autoload": {
        "psr-4": {
            "Mcamara\\LaravelLocalization\\": "src/Mcamara/LaravelLocalization/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mcamara\\LaravelLocalization\\LaravelLocalizationServiceProvider"
            ],
            "aliases": {
                "LaravelLocalization": "Mcamara\\LaravelLocalization\\Facades\\LaravelLocalization"
            }
        }
    }
}
